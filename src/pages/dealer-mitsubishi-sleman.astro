---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Dealer Mitsubishi Sleman | Sales Resmi Putra – Sun Star Motor Sleman" description="Dealer Mitsubishi Sleman resmi – Sun Star Motor Jl. Magelang Km. 14 (depan RSUD Sleman). Hubungi Putra, Sales Consultant terpercaya untuk pembelian unit baru dengan layanan door to door." image="/images/placeholder.svg">
    <Fragment slot="head">
        <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "AutoDealer",
      "name": "Mitsubishi Sleman - Sun Star Motor (Putra Sales)",
      "image": "https://mitsubishi-sleman.online/images/placeholder.svg",
      "url": "https://mitsubishi-sleman.online",
      "telephone": "+628974362666",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Jl. Magelang km. 14, Medari, Triharjo",
        "addressLocality": "Sleman",
        "addressRegion": "Daerah Istimewa Yogyakarta",
        "postalCode": "55514",
        "addressCountry": "ID"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -7.6975217,
        "longitude": 110.337775
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "08:30",
          "closes": "16:30"
        }
      ]
    }
    </script>
    </Fragment>

<Breadcrumb items={[
    { label: "Dealer Mitsubishi Sleman" }
]} />

    <!-- Page Hero -->
    <div class="page-hero">
        <h1>Dealer Resmi Mitsubishi Sleman</h1>
        <p>Sun Star Motor Sleman – Pelayanan Pembelian Unit Baru Terbaik di Jogja bersama Putra.</p>
    </div>

    <!-- Layout Dealer -->
    <div class="dealer-layout">
        <!-- Main Info -->
        <div class="product-main">
            <!-- Tentang Dealer -->
            <div class="product-card">
                <h2>Sun Star Motor Sleman</h2>
                <img src="/images/placeholder.svg" alt="Showroom Dealer Mitsubishi Sun Star Motor Sleman" style="width: 100%; border-radius: 8px; margin-bottom: 1rem; box-shadow: var(--shadow);" loading="lazy">
                <p style="line-height: 1.8; color: var(--m-dark-grey); margin-bottom: 1rem;">
                    Selamat datang di dealer resmi <strong>Mitsubishi Sun Star Motor Sleman</strong>. Berlokasi strategis di Jl. Magelang Km. 14 (tepat di depan RSUD Sleman), kami siap melayani warga Kabupaten Sleman dan seluruh area Daerah Istimewa Yogyakarta untuk mewujudkan mobil impian Anda.
                </p>
                <p style="line-height: 1.8; color: var(--m-dark-grey);">
                    Fasilitas kami berstandar internasional (3S: Sales, Service, Sparepart), memastikan Anda mendapatkan pengalaman terbaik mulai dari test drive, pemilihan unit, proses kredit yang dibantu penuh, hingga layanan purna jual. Konsultasikan kebutuhan Anda bersama <strong>Putra</strong>, Sales Consultant Mitsubishi berpengalaman yang akan melayani Anda secara door-to-door.
                </p>
            </div>

            <!-- Layanan Kami -->
            <div class="product-card">
                <h2>Fasilitas &amp; Layanan Kami</h2>
                <div class="info-box-grid">
                    <div class="info-box">
                        <i class="fas fa-car info-box-icon" style="color: var(--m-red);"></i>
                        <div>
                            <div class="info-box-title">Showroom &amp; Sales</div>
                            <div class="info-box-text">Display unit lengkap Xpander, Xforce, Pajero Sport, truk Fuso &amp; Colt Diesel (L300). Proses cepat.</div>
                        </div>
                    </div>
                    <div class="info-box">
                        <i class="fas fa-tools info-box-icon" style="color: var(--m-red);"></i>
                        <div>
                            <div class="info-box-title">Bengkel Resmi (Service)</div>
                            <div class="info-box-text">Mekanik bersertifikat Mitsubishi, ruang tunggu super nyaman b-AC plus snack gratis.</div>
                        </div>
                    </div>
                    <div class="info-box">
                        <i class="fas fa-cogs info-box-icon" style="color: var(--m-red);"></i>
                        <div>
                            <div class="info-box-title">Suku Cadang (Sparepart)</div>
                            <div class="info-box-text">Hanya menyediakan sparepart asli (Mitsubishi Genuine Parts) untuk performa awet.</div>
                        </div>
                    </div>
                    <div class="info-box">
                        <i class="fas fa-home info-box-icon" style="color: var(--m-red);"></i>
                        <div>
                            <div class="info-box-title">Test Drive ke Rumah</div>
                            <div class="info-box-text">Sibuk? Putra akan bawakan unit test drive langsung ke rumah atau kantor Anda di Sleman.</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Peta Lokasi -->
            <div class="product-card">
                <h2>Peta Lokasi Kami</h2>
                <p style="font-size: 0.95rem; color: var(--m-dark-grey); margin-bottom: 12px;"><strong>Alamat:</strong> Jl. Magelang km. 14, Medari, Triharjo, Kabupaten Sleman, Daerah Istimewa Yogyakarta 55514 (Depan RSUD Sleman)</p>
                <div class="map-container">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15814.739665977322!2d110.32747515000001!3d-7.6975217!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e7a5facafffffeb%3A0xc6cb5dae9ca2a5ab!2sDealer%20Mitsubishi%20Sun%20Star%20Motor%20Sleman!5e0!3m2!1sen!2sid!4v1700450000000!5m2!1sen!2sid" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
        </div>

        <!-- Sidebar Contact Info -->
        <div class="product-sidebar">
            <div class="sidebar-widget">
                <h3 style="display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-user-circle" style="color: var(--m-red); font-size: 1.4rem;"></i>
                    Sales Consultant
                </h3>
                <div style="text-align: center; padding: 1rem 0;">
                    <img src="/images/placeholder.svg" alt="Putra Sales Mitsubishi Sleman" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid var(--m-red); margin-bottom: 12px;" loading="lazy">
                    <h4 style="font-size: 1.2rem; color: var(--m-black);">Putra</h4>
                    <p style="font-size: 0.9rem; color: var(--m-mid-grey); margin-top: 4px;">Sales Resmi Mitsubishi Sleman</p>
                </div>
                <a href="https://wa.me/628974362666?text=Halo%20Putra%2C%20saya%20mau%20konsultasi%20pembelian%20mobil%20Mitsubishi%20di%20Sleman" class="cta-btn cta-btn--block" style="margin-top: 0.5rem;" target="_blank" rel="noopener">
                    <i class="fab fa-whatsapp"></i> Chat Saya Sekarang
                </a>
                <a href="tel:+628974362666" class="cta-btn cta-btn--block" style="margin-top: 10px; background: white; color: var(--m-red); border: 1px solid var(--m-red);">
                    <i class="fas fa-phone"></i> Hubungi 0897-4362-666
                </a>
            </div>

            <div class="sidebar-widget" style="margin-top: 1.5rem;">
                <h3>Jam Operasional</h3>
                <p style="font-size: 0.85rem; color: var(--m-mid-grey); margin-bottom: 8px;">
                    Buka untuk pelayanan di showroom bengkel:
                </p>
                <table class="jam-ops-table">
                    <tr>
                        <td>Senin - Jumat</td>
                        <td>08:30 - 16:30</td>
                    </tr>
                    <tr>
                        <td>Sabtu</td>
                        <td>08:30 - 14:30</td>
                    </tr>
                    <tr>
                        <td>Minggu/Libur</td>
                        <td>Tutup (Bisa janjian luar jam buka)</td>
                    </tr>
                </table>
                <p style="font-size: 0.8rem; color: var(--m-red); font-style: italic; margin-top: 12px; line-height: 1.5;">
                    * Layanan konsultasi online / WhatsApp Putra Buka 24 Jam. Jangan ragu untuk chat kapanpun.
                </p>
            </div>
            
            <div class="sidebar-widget" style="margin-top: 1.5rem;">
                <h3>Pusat Promo Unit</h3>
                <ul class="sidebar-link-list">
                    <li><a href="/xpander-sleman.html">→ Promo New Xpander</a></li>
                    <li><a href="/xforce-jogja.html">→ Promo Xforce</a></li>
                    <li><a href="/pajero-sport-sleman.html">→ Promo Pajero Sport</a></li>
                </ul>
            </div>
        </div>
    </div>
    
</Layout>
