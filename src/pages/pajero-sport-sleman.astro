---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SidebarCTA from '../components/SidebarCTA.astro';
import RelatedProducts from '../components/RelatedProducts.astro';
---

<Layout title="Harga Pajero Sport Sleman 2026 | Promo Bunga 0% – Mitsubishi Sleman" description="Harga terbaru Mitsubishi Pajero Sport di Sleman Yogyakarta 2026. Promo bunga 0%, bonus kaca film V-Kool, test drive door to door. Hubungi Putra – Sales Resmi Mitsubishi." image="/images/placeholder.svg">
    <Fragment slot="head">
        <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Mitsubishi Pajero Sport 2026",
      "image": "https://mitsubishi-sleman.online/images/placeholder.svg",
      "description": "SUV premium Mitsubishi Pajero Sport dengan mesin diesel 4N15 MIVEC 181 PS. Tersedia di Sleman Yogyakarta melalui Putra Sales.",
      "brand": { "@type": "Brand", "name": "Mitsubishi" },
      "offers": [
        {
          "@type": "Offer",
          "name": "Pajero Sport Exceed AT 4x2",
          "priceCurrency": "IDR",
          "price": "724000000",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "AutoDealer", "name": "Mitsubishi Sleman – Putra Sales", "url": "https://mitsubishi-sleman.online" },
          "priceValidUntil": "2026-12-31"
        },
        {
          "@type": "Offer",
          "name": "Pajero Sport Dakar AT 4x4",
          "priceCurrency": "IDR",
          "price": "799000000",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "AutoDealer", "name": "Mitsubishi Sleman – Putra Sales", "url": "https://mitsubishi-sleman.online" }
        }
      ]
    }
    </script>
    </Fragment>

<Breadcrumb items={[
    { label: "Produk", href: "/#products" },
    { label: "Pajero Sport Sleman" }
]} />

    <div class="page-hero">
        <h1>Harga Mitsubishi Pajero Sport Sleman 2026</h1>
        <p>Promo Bunga 0% + Bonus Kaca Film V-Kool &amp; Karpet Dasar. Test Drive Door to Door Sleman.</p>
    </div>

    <div class="product-layout">
        <div class="product-main">

            <img src="/images/placeholder.svg" alt="Mitsubishi Pajero Sport Dakar 2026 – Sleman Yogyakarta" class="product-image-main" loading="lazy">

            <!-- Promo Banner -->
            <div style="background: linear-gradient(135deg, var(--m-red), #8b0000); color: white; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; text-align: center;">
                <div style="font-size: 1.4rem; font-weight: bold; margin-bottom: 6px;">🎉 PROMO SPESIAL BULAN INI</div>
                <p style="opacity: 0.95; font-size: 1rem;">Bunga 0% hingga 12 bulan + Bonus Kaca Film V-Kool + Karpet Dasar<br>Khusus pembelian Pajero Sport Dakar unit ready stok!</p>
                <a href="https://wa.me/628974362666?text=Halo%20Putra%2C%20saya%20mau%20klaim%20promo%20Pajero%20Sport%20Dakar"
                   class="cta-btn" style="background: white; color: var(--m-red); margin-top: 14px; display: inline-block;" target="_blank" rel="noopener">
                   Klaim Promo Sekarang 🚀
                </a>
            </div>

            <!-- Harga & Varian -->
            <div class="product-card">
                <h2>Harga Pajero Sport Sleman 2026</h2>
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>Varian</th>
                            <th>Penggerak</th>
                            <th class="price-col">Harga OTR Jogja</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Pajero Sport Exceed</td>
                            <td>AT 4x2</td>
                            <td class="price-col">Rp 724.000.000</td>
                        </tr>
                        <tr>
                            <td>Pajero Sport Exceed</td>
                            <td>AT 4x4</td>
                            <td class="price-col">Rp 769.000.000</td>
                        </tr>
                        <tr>
                            <td>Pajero Sport Dakar</td>
                            <td>AT 4x2</td>
                            <td class="price-col">Rp 777.000.000</td>
                        </tr>
                        <tr style="background: #fff5f5;">
                            <td><strong>Pajero Sport Dakar Ultimate</strong></td>
                            <td>AT 4x4</td>
                            <td class="price-col"><strong>Rp 799.000.000</strong></td>
                        </tr>
                    </tbody>
                </table>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey); margin-top: 8px;">* Harga OTR Yogyakarta. Konfirmasi unit stok &amp; klaim bonus langsung ke Putra via WhatsApp.</p>
            </div>

            <!-- Spesifikasi -->
            <div class="product-card">
                <h2>Spesifikasi Mesin &amp; Utama</h2>
                <table class="spec-table">
                    <tr><th>Mesin</th><td>4N15 MIVEC Turbocharged DOHC</td></tr>
                    <tr><th>Kapasitas Mesin</th><td>2.442 cc diesel</td></tr>
                    <tr><th>Tenaga Maks</th><td>181 PS @ 3.500 rpm</td></tr>
                    <tr><th>Torsi Maks</th><td>430 Nm @ 2.500 rpm</td></tr>
                    <tr><th>Transmisi</th><td>8-Speed Sport AT</td></tr>
                    <tr><th>Sistem 4WD</th><td>Super Select 4WD-II (4x4 varian)</td></tr>
                    <tr><th>Kapasitas</th><td>7 Penumpang</td></tr>
                    <tr><th>Ground Clearance</th><td>218 mm</td></tr>
                    <tr><th>Konsumsi BBM</th><td>±11–13 km/L (solar)</td></tr>
                    <tr><th>Emisi</th><td>Euro 4</td></tr>
                </table>
                <div class="feature-pills">
                    <span class="feature-pill">Sunroof Panoramic</span>
                    <span class="feature-pill">360° Camera</span>
                    <span class="feature-pill">Adaptive Cruise Control</span>
                    <span class="feature-pill">Lane Departure Warning</span>
                    <span class="feature-pill">Wireless Charger</span>
                    <span class="feature-pill">Apple CarPlay / Android Auto</span>
                    <span class="feature-pill">8 Airbags</span>
                    <span class="feature-pill">Electric Tailgate</span>
                </div>
            </div>

            <!-- Simulasi Kredit -->
            <div class="product-card">
                <h2>Simulasi Kredit Pajero Sport Sleman</h2>
                <p style="font-size: 0.9rem; margin-bottom: 1rem; color: var(--m-mid-grey);">Estimasi kredit Pajero Sport Dakar 4x4 (OTR Rp 799.000.000), DP 20%:</p>
                <div class="kredit-grid">
                    <div class="kredit-card">
                        <div class="k-label">DP 20%</div>
                        <div class="k-value">Rp 159,8 Jt</div>
                        <div class="k-sub">Payable upfront</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Cicilan/Bulan</div>
                        <div class="k-value">~Rp 19,5 Jt</div>
                        <div class="k-sub">Tenor 36 bulan</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Cicilan/Bulan</div>
                        <div class="k-value">~Rp 14,2 Jt</div>
                        <div class="k-sub">Tenor 60 bulan</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Bunga Promo</div>
                        <div class="k-value">0%</div>
                        <div class="k-sub">Hingga 12 bulan</div>
                    </div>
                </div>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey); margin-top: 12px;">* Simulasi perkiraan. Hubungi Putra untuk penghitungan kredit&amp;promo yang tepat &amp; update.</p>
            </div>

            <!-- Keunggulan Lokal -->
            <div class="product-card">
                <h2>Keunggulan Pajero Sport untuk Medan Yogyakarta</h2>
                <ul class="about-list" style="margin-top: 0.5rem;">
                    <li>Ground clearance 218 mm – cocok untuk jalan rusak, perkebunan, atau gunung sekitar Sleman-Magelang</li>
                    <li>Mesin diesel 4N15 – torsi besar 430 Nm sangat tangguh di tanjakan Kaliurang &amp; Merapi</li>
                    <li>Kapasitas solar besar – efisien untuk perjalanan Jogja-Semarang-Solo</li>
                    <li>7 penumpang – ideal untuk keluarga besar atau rombongan wisata lokal</li>
                    <li>Pilihan 4x4 Super Select – untuk adventurer Sleman yang suka off-road</li>
                </ul>
            </div>

        </div>

        <!-- Sidebar -->
        <div class="product-sidebar">
            <SidebarCTA
                image="/images/placeholder.svg"
                imageAlt="Pajero Sport"
                price="Rp 724 Juta"
                waLink="https://wa.me/628974362666?text=Halo%20Putra%2C%20saya%20tertarik%20Pajero%20Sport%20di%20Sleman.%20Bisakah%20info%20promo%20terkini%3F"
                waButtonText="Klaim Promo Pajero"
                ctaId="wa-pajero-cta"
                promoBadge="🎉 PROMO: Bunga 0% + Bonus Aktif"
                features={["Bunga 0% hingga 12 bulan", "Bonus Kaca Film V-Kool", "Test Drive Door to Door"]}
            />

            <div class="sidebar-widget" style="margin-top: 1.5rem;">
                <h3>Produk Lainnya</h3>
                <ul class="sidebar-link-list">
                    <li><a href="/xpander-sleman.html">→ New Xpander Sleman</a></li>
                    <li><a href="/xforce-jogja.html">→ New Xforce Jogja</a></li>
                    <li><a href="/#products">→ Lihat Semua Unit</a></li>
                </ul>
            </div>
            <div class="sidebar-widget" style="margin-top: 1.5rem;">
                <h3>Artikel Berguna</h3>
                <ul class="sidebar-link-list">
                    <li><a href="/blog/kredit-mitsubishi-sleman.html">Tips Kredit Mitsubishi Sleman</a></li>
                    <li><a href="/blog/perbandingan-xpander-vs-xforce.html">Xpander vs XForce – Mana Pilihan Terbaik?</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Related -->
    <RelatedProducts products={[
        { title: "New Xpander Cross – MPV Terlaris", price: "Rp 377.500.000", image: "/images/placeholder.svg", alt: "Xpander Cross Sleman", href: "/xpander-sleman.html" },
        { title: "New Xforce – Compact SUV", price: "Rp 428.500.000", image: "/images/placeholder.svg", alt: "Xforce Jogja", href: "/xforce-jogja.html" }
    ]} />

    
</Layout>
