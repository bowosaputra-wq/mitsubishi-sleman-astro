---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SidebarCTA from '../components/SidebarCTA.astro';
import RelatedProducts from '../components/RelatedProducts.astro';
---

<Layout title="Harga Xpander Sleman 2026 | Promo DP Rendah – Mitsubishi Sleman" description="Harga dan promo Mitsubishi Xpander terbaru di Sleman Yogyakarta 2026. DP mulai 10%, kredit mudah, test drive door to door. Hubungi Putra – Sales Resmi Mitsubishi Sleman." image="/images/xpander-cross.webp">
    <Fragment slot="head">
        <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Mitsubishi New Xpander / Xpander Cross",
      "image": "https://mitsubishi-sleman.online/images/xpander-cross.webp",
      "description": "MPV tangguh dengan kenyamanan maksimal untuk keluarga. Tersedia di Sleman Yogyakarta melalui Putra Sales.",
      "brand": { "@type": "Brand", "name": "Mitsubishi" },
      "offers": [
        {
          "@type": "Offer",
          "name": "New Xpander GLS",
          "priceCurrency": "IDR",
          "price": "350000000",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "AutoDealer", "name": "Mitsubishi Sleman – Putra Sales", "url": "https://mitsubishi-sleman.online" },
          "validFrom": "2026-01-01",
          "areaServed": "Sleman, Yogyakarta"
        },
        {
          "@type": "Offer",
          "name": "New Xpander Cross",
          "priceCurrency": "IDR",
          "price": "377500000",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "AutoDealer", "name": "Mitsubishi Sleman – Putra Sales", "url": "https://mitsubishi-sleman.online" }
        }
      ]
    }
    </script>
    </Fragment>

<Breadcrumb items={[
    { label: "Produk", href: "/#products" },
    { label: "New Xpander Sleman" }
]} />

    <!-- Page Hero -->
    <div class="page-hero">
        <h1>Harga Mitsubishi Xpander Sleman 2026</h1>
        <p>Promo DP Rendah, Kredit Mudah, Test Drive Door to Door se-Sleman &amp; Yogyakarta</p>
    </div>

    <!-- Product Layout -->
    <div class="product-layout">

        <!-- Main Content -->
        <div class="product-main">

            <!-- Hero Image -->
            <img src="/images/xpander-cross.webp" alt="Mitsubishi New Xpander Cross 2026 – Sleman Yogyakarta" class="product-image-main">

            <!-- Harga & Varian -->
            <div class="product-card">
                <h2>Harga Xpander Sleman 2026</h2>
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>Varian</th>
                            <th>Tipe</th>
                            <th class="price-col">Harga OTR Jogja</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>New Xpander GLS</td>
                            <td>MT / AT</td>
                            <td class="price-col">Rp 350.000.000</td>
                        </tr>
                        <tr>
                            <td>New Xpander Exceed</td>
                            <td>AT</td>
                            <td class="price-col">Rp 362.500.000</td>
                        </tr>
                        <tr>
                            <td>New Xpander Ultimate</td>
                            <td>AT</td>
                            <td class="price-col">Rp 375.000.000</td>
                        </tr>
                        <tr>
                            <td>New Xpander Cross</td>
                            <td>MT / AT</td>
                            <td class="price-col">Rp 377.500.000</td>
                        </tr>
                        <tr>
                            <td>New Xpander Cross Premium</td>
                            <td>AT</td>
                            <td class="price-col">Rp 395.000.000</td>
                        </tr>
                    </tbody>
                </table>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey); margin-top: 8px;">* Harga OTR Yogyakarta, dapat berubah sewaktu-waktu. Hubungi Putra untuk harga terkini + promo bonus.</p>
            </div>

            <!-- Spesifikasi -->
            <div class="product-card">
                <h2>Spesifikasi Utama</h2>
                <table class="spec-table">
                    <tr><th>Mesin</th><td>MIVEC 1.499 cc, DOHC 16 valve</td></tr>
                    <tr><th>Tenaga Maks</th><td>105 PS @ 6.000 rpm</td></tr>
                    <tr><th>Torsi Maks</th><td>141 Nm @ 4.000 rpm</td></tr>
                    <tr><th>Transmisi</th><td>Manual 5-speed / CVT Otomatis</td></tr>
                    <tr><th>Kapasitas</th><td>7 Penumpang</td></tr>
                    <tr><th>Konsumsi BBM</th><td>±14–16 km/L (jalan tol)</td></tr>
                    <tr><th>Dimensi (PxLxT)</th><td>4.475 × 1.750 × 1.700 mm</td></tr>
                    <tr><th>Wheelbase</th><td>2.775 mm</td></tr>
                    <tr><th>Kapasitas Bagasi</th><td>180 L (7 penumpang) / 803 L (5 penumpang)</td></tr>
                    <tr><th>Bahan Bakar</th><td>Bensin (Pertalite/Pertamax)</td></tr>
                </table>
                <div class="feature-pills">
                    <span class="feature-pill">7 Seater</span>
                    <span class="feature-pill">Touchscreen 8"</span>
                    <span class="feature-pill">Cruise Control</span>
                    <span class="feature-pill">Adaptive Cruise (Cross)</span>
                    <span class="feature-pill">LED Headlamp</span>
                    <span class="feature-pill">Parkir Sensor</span>
                    <span class="feature-pill">Apple CarPlay</span>
                    <span class="feature-pill">Android Auto</span>
                </div>
            </div>

            <!-- Simulasi Kredit -->
            <div class="product-card">
                <h2>Simulasi Kredit Xpander Sleman</h2>
                <p style="font-size: 0.9rem; margin-bottom: 1rem; color: var(--m-mid-grey);">Estimasi kredit New Xpander GLS AT (OTR Rp 362.500.000), DP 20%:</p>
                <div class="kredit-grid">
                    <div class="kredit-card">
                        <div class="k-label">DP 20%</div>
                        <div class="k-value">Rp 72,5 Jt</div>
                        <div class="k-sub">Cicilan 36 bln</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Cicilan/Bulan</div>
                        <div class="k-value">~Rp 8,9 Jt</div>
                        <div class="k-sub">Tenor 36 bulan</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Cicilan/Bulan</div>
                        <div class="k-value">~Rp 6,4 Jt</div>
                        <div class="k-sub">Tenor 60 bulan</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">DP Minimal</div>
                        <div class="k-value">10%</div>
                        <div class="k-sub">± Rp 36 Juta</div>
                    </div>
                </div>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey); margin-top: 12px;">* Simulasi perkiraan. Hubungi Putra untuk penghitungan kredit pasti sesuai kondisi Anda.</p>
                <a href="/blog/kredit-mitsubishi-sleman.html" style="font-size: 0.88rem; font-weight: 600; margin-top: 8px; display: inline-block;">📖 Baca: Tips Kredit Mitsubishi Sleman →</a>
            </div>

            <!-- Keunggulan -->
            <div class="product-card">
                <h2>Mengapa Pilih Xpander di Sleman?</h2>
                <ul class="about-list" style="margin-top: 0.5rem;">
                    <li>Ruang kabin terluas di kelasnya – ideal untuk keluarga Sleman dengan aktivitas padat</li>
                    <li>Ground clearance 205 mm – aman melewati jalan gang &amp; pedesaan sekitar Sleman</li>
                    <li>Bagasi luas bisa lipat – cocok untuk belanja pasar atau liburan ke Kaliurang</li>
                    <li>BBM Pertalite – hemat di keseharian kota Yogyakarta</li>
                    <li>After sales resmi – bengkel Sun Star Motor terdekat di Jl. Magelang</li>
                </ul>
            </div>

        </div>

        <!-- Sidebar Sticky CTA -->
        <div class="product-sidebar">
            <SidebarCTA
                image="/images/xpander.webp"
                imageAlt="Xpander"
                price="Rp 350 Juta"
                waLink="https://wa.me/628974362666?text=Halo%20Putra%2C%20saya%20tertarik%20Xpander%20di%20Sleman.%20Boleh%20info%20promo%20terkini%3F"
                waButtonText="Chat Promo Xpander"
                ctaId="wa-xpander-cta"
                features={["Test Drive Door to Door", "DP mulai 10%", "Kredit diproses 1 hari"]}
            />

            <!-- Related Links -->
            <div class="sidebar-widget" style="margin-top: 1.5rem;">
                <h3>Produk Lainnya</h3>
                <ul class="sidebar-link-list">
                    <li><a href="/pajero-sport-sleman.html">→ Pajero Sport Sleman</a></li>
                    <li><a href="/xforce-jogja.html">→ Xforce Jogja</a></li>
                    <li><a href="/#products">→ Lihat Semua Unit</a></li>
                </ul>
            </div>
            <div class="sidebar-widget" style="margin-top: 1.5rem;">
                <h3>Artikel Berguna</h3>
                <ul class="sidebar-link-list">
                    <li><a href="/blog/kredit-mitsubishi-sleman.html">Tips Kredit Mitsubishi Sleman</a></li>
                    <li><a href="/blog/perbandingan-xpander-vs-xforce.html">Xpander vs XForce – Mana Pilihan Terbaik?</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    <RelatedProducts products={[
        { title: "Pajero Sport – Promo Bunga 0%", price: "Rp 799.000.000", image: "/images/pajero-sport.webp", alt: "Pajero Sport Sleman", href: "/pajero-sport-sleman.html" },
        { title: "New Xforce – Compact SUV", price: "Rp 428.500.000", image: "/images/xforce.webp", alt: "Xforce Jogja", href: "/xforce-jogja.html" }
    ]} />

    <!-- Floating WhatsApp -->
    
</Layout>
