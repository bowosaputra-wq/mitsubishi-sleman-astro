---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Harga Xforce Jogja 2026 | SUV Compact Terbaik – Mitsubishi Sleman" description="Harga dan promo Mitsubishi Xforce terbaru di Jogja &amp; Sleman 2026. Audio Yamaha Premium, sunroof, kredit mudah. Test drive door to door. Hubungi Putra Sales Mitsubishi.">
    <Fragment slot="head">
        <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Mitsubishi New Xforce 2026",
      "image": "https://mitsubishi-sleman.online/images/xforce.webp",
      "description": "Compact SUV futuristik dengan audio Yamaha Premium dan teknologi dynamic shield. Tersedia di Sleman &amp; Yogyakarta.",
      "brand": { "@type": "Brand", "name": "Mitsubishi" },
      "offers": [
        {
          "@type": "Offer",
          "name": "Xforce GLS MT",
          "priceCurrency": "IDR",
          "price": "374500000",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "AutoDealer", "name": "Mitsubishi Sleman – Putra Sales", "url": "https://mitsubishi-sleman.online" }
        },
        {
          "@type": "Offer",
          "name": "Xforce Ultimate AT",
          "priceCurrency": "IDR",
          "price": "428500000",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "AutoDealer", "name": "Mitsubishi Sleman – Putra Sales", "url": "https://mitsubishi-sleman.online" }
        }
      ]
    }
    </script>
    </Fragment>

<div class="breadcrumb">
        <div class="breadcrumb-inner">
            <a href="/">Home</a><span>›</span>
            <a href="/#products">Produk</a><span>›</span>
            <span class="current">New Xforce Jogja</span>
        </div>
    </div>

    <div class="page-hero">
        <h1>Harga Mitsubishi Xforce Jogja 2026</h1>
        <p>Compact SUV Futuristik – Audio Yamaha Premium, Sunroof, Kredit Mudah di Sleman &amp; Yogyakarta</p>
    </div>

    <div class="product-layout">
        <div class="product-main">

            <img src="/images/xforce.webp" alt="Mitsubishi New Xforce 2026 Jogja Sleman" class="product-image-main">

            <!-- Harga & Varian -->
            <div class="product-card">
                <h2>Harga Xforce Jogja 2026</h2>
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>Varian</th>
                            <th>Transmisi</th>
                            <th class="price-col">Harga OTR Jogja</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Xforce GLS</td>
                            <td>MT (Manual)</td>
                            <td class="price-col">Rp 374.500.000</td>
                        </tr>
                        <tr>
                            <td>Xforce GLS</td>
                            <td>CVT (Otomatis)</td>
                            <td class="price-col">Rp 388.500.000</td>
                        </tr>
                        <tr>
                            <td>Xforce Exceed</td>
                            <td>CVT</td>
                            <td class="price-col">Rp 408.500.000</td>
                        </tr>
                        <tr style="background: #fff5f5;">
                            <td><strong>Xforce Ultimate</strong></td>
                            <td>CVT</td>
                            <td class="price-col"><strong>Rp 428.500.000</strong></td>
                        </tr>
                    </tbody>
                </table>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey); margin-top: 8px;">* Harga OTR Yogyakarta. Stok terbatas – hubungi Putra untuk konfirmasi ketersediaan unit.</p>
            </div>

            <!-- Spesifikasi -->
            <div class="product-card">
                <h2>Spesifikasi Utama New Xforce</h2>
                <table class="spec-table">
                    <tr><th>Mesin</th><td>1.499 cc MIVEC DOHC 16 valve</td></tr>
                    <tr><th>Tenaga Maks</th><td>105 PS @ 6.000 rpm</td></tr>
                    <tr><th>Torsi Maks</th><td>141 Nm @ 4.000 rpm</td></tr>
                    <tr><th>Transmisi</th><td>Manual 5-speed / INVECS-III CVT</td></tr>
                    <tr><th>Kapasitas</th><td>5 Penumpang</td></tr>
                    <tr><th>Ground Clearance</th><td>205 mm</td></tr>
                    <tr><th>Konsumsi BBM</th><td>±15–17 km/L</td></tr>
                    <tr><th>Dimensi (PxLxT)</th><td>4.390 × 1.810 × 1.640 mm</td></tr>
                    <tr><th>Kapasitas Bagasi</th><td>358 L</td></tr>
                    <tr><th>Bahan Bakar</th><td>Bensin (Pertamax dianjurkan)</td></tr>
                </table>
                <div class="feature-pills" style="margin-top: 1rem;">
                    <span class="feature-pill">Audio Yamaha 8 Speaker</span>
                    <span class="feature-pill">Panoramic Sunroof</span>
                    <span class="feature-pill">360° Monitor</span>
                    <span class="feature-pill">Wireless Charger</span>
                    <span class="feature-pill">Apple CarPlay</span>
                    <span class="feature-pill">Android Auto</span>
                    <span class="feature-pill">Lane Departure Warning</span>
                    <span class="feature-pill">Auto High Beam</span>
                </div>
            </div>

            <!-- Simulasi Kredit -->
            <div class="product-card">
                <h2>Simulasi Kredit Xforce Jogja</h2>
                <p style="font-size: 0.9rem; margin-bottom: 1rem; color: var(--m-mid-grey);">Estimasi kredit Xforce Exceed CVT (OTR Rp 408.500.000), DP 20%:</p>
                <div class="kredit-grid">
                    <div class="kredit-card">
                        <div class="k-label">DP 20%</div>
                        <div class="k-value">Rp 81,7 Jt</div>
                        <div class="k-sub">Payable upfront</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Cicilan/Bulan</div>
                        <div class="k-value">~Rp 10,1 Jt</div>
                        <div class="k-sub">Tenor 36 bulan</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Cicilan/Bulan</div>
                        <div class="k-value">~Rp 7,3 Jt</div>
                        <div class="k-sub">Tenor 60 bulan</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">DP Minimal</div>
                        <div class="k-value">10%</div>
                        <div class="k-sub">± Rp 40,8 Juta</div>
                    </div>
                </div>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey); margin-top: 12px;">* Simulasi perkiraan. Hubungi Putra untuk penghitungan kredit pasti sesuai kebutuhan Anda.</p>
            </div>

            <!-- Keunggulan -->
            <div class="product-card">
                <h2>Mengapa Xforce Cocok untuk Pengguna Jogja &amp; Sleman?</h2>
                <ul class="about-list" style="margin-top: 0.5rem;">
                    <li>Ukuran compact – mudah bermanuver di jalan sempit kota Yogyakarta &amp; sekitar UGM/UNY</li>
                    <li>Ground clearance 205 mm – nyaman melewati jalan bergelombang khas Sleman Utara</li>
                    <li>Audio Yamaha 8 speaker – pengalaman berkendara premium di jalur Jogja-Solo</li>
                    <li>Sunroof panoramic – nikmati udara segar khas daerah Sleman sambil berkendara</li>
                    <li>Desain Dynamic Shield – tampil standout di jalanan Jogja yang stylish</li>
                </ul>
            </div>

            <!-- Comparison teaser -->
            <div style="background: #f0f8ff; border-radius: 12px; padding: 1.5rem; border: 1px solid #cce0ff;">
                <h3 style="margin-bottom: 8px; font-size: 1.05rem;">🤔 Bingung Pilih Xpander atau Xforce?</h3>
                <p style="font-size: 0.9rem; line-height: 1.7; margin-bottom: 12px;">Kami sudah buat perbandingan lengkap keduanya – dari kapasitas, harga kredit, hingga cocok untuk keluarga mana di Sleman.</p>
                <a href="/blog/perbandingan-xpander-vs-xforce.html" class="cta-btn-outline">Baca Perbandingan Lengkap →</a>
            </div>

        </div>

