---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SidebarCTA from '../components/SidebarCTA.astro';
import RelatedProducts from '../components/RelatedProducts.astro';
---

<Layout title="Harga Xforce Jogja 2026 | SUV Compact Terbaik – Mitsubishi Sleman" description="Harga dan promo Mitsubishi Xforce terbaru di Jogja &amp; Sleman 2026. Audio Yamaha Premium, sunroof, kredit mudah. Test drive door to door. Hubungi Putra Sales Mitsubishi." image="/images/xforce.webp">
    <Fragment slot="head">
        <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Mitsubishi XForce 2026",
      "image": "https://mitsubishi-sleman.online/images/xforce.webp",
      "description": "Compact SUV premium dengan desain futuristik dan audio Yamaha. Tersedia di Sleman Yogyakarta melalui Putra Sales.",
      "brand": { "@type": "Brand", "name": "Mitsubishi" },
      "offers": [
        {
          "@type": "Offer",
          "name": "XForce Exceed CVT",
          "priceCurrency": "IDR",
          "price": "382500000",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "AutoDealer", "name": "Mitsubishi Sleman – Putra Sales", "url": "https://mitsubishi-sleman.online" }
        },
        {
          "@type": "Offer",
          "name": "XForce Ultimate CVT",
          "priceCurrency": "IDR",
          "price": "428500000",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "AutoDealer", "name": "Mitsubishi Sleman – Putra Sales", "url": "https://mitsubishi-sleman.online" }
        }
      ]
    }
    </script>
    </Fragment>

<Breadcrumb items={[
    { label: "Produk", href: "/#products" },
    { label: "Mitsubishi Xforce Jogja" }
]} />

    <div class="page-hero">
        <h1>Harga Mitsubishi Xforce Jogja 2026</h1>
        <p>SUV Compact Paling Stylish. Promo DP Rendah &amp; Kredit Cepat se-Yogyakarta. Bawa Pulang XForce Impianmu!</p>
    </div>

    <div class="product-layout">
        <div class="product-main">

            <img src="/images/xforce.webp" alt="Mitsubishi Xforce Ultimate 2026 – Sleman Yogyakarta" class="product-image-main">

            <!-- Harga & Varian -->
            <div class="product-card">
                <h2>Harga Xforce Jogja 2026</h2>
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>Varian</th>
                            <th>Transmisi</th>
                            <th class="price-col">Harga OTR Jogja</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Xforce Exceed</td>
                            <td>CVT</td>
                            <td class="price-col">Rp 382.500.000</td>
                        </tr>
                        <tr style="background: #fff5f5;">
                            <td><strong>Xforce Ultimate</strong></td>
                            <td>CVT</td>
                            <td class="price-col"><strong>Rp 428.500.000</strong></td>
                        </tr>
                    </tbody>
                </table>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey); margin-top: 8px;">* Harga OTR Yogyakarta. Promo tambahan &amp; diskon akhir tahun? Langsung chat/telepon Putra!</p>
            </div>

            <!-- Spesifikasi -->
            <div class="product-card">
                <h2>Canggihnya Fitur Xforce</h2>
                <table class="spec-table">
                    <tr><th>Mesin</th><td>1.499 cc, MIVEC DOHC 16 Valve</td></tr>
                    <tr><th>Tenaga Maks</th><td>105 PS @ 6.000 rpm</td></tr>
                    <tr><th>Torsi Maks</th><td>141 Nm @ 4.000 rpm</td></tr>
                    <tr><th>Transmisi</th><td>CVT dengan 4 Mode Berkendara</td></tr>
                    <tr><th>Mode Berkendara</th><td>Normal, Wet, Gravel, Mud</td></tr>
                    <tr><th>Audio</th><td>Yamaha Premium Sound (8 Speaker)</td></tr>
                    <tr><th>Head Unit</th><td>12.3 inch Smartphone-link</td></tr>
                    <tr><th>Ground Clearance</th><td>222 mm (Tertinggi di kelasnya!)</td></tr>
                    <tr><th>Kapasitas</th><td>5 Penumpang</td></tr>
                    <tr><th>Rem</th><td>Cakram Depan &amp; Belakang + EPB</td></tr>
                </table>
                <div class="feature-pills">
                    <span class="feature-pill">Yamaha Sound System</span>
                    <span class="feature-pill">Layar 12.3" Panel Touch</span>
                    <span class="feature-pill">Drive Modes</span>
                    <span class="feature-pill">Power Tailgate + Kick Sensor</span>
                    <span class="feature-pill">Air Purifier NanoeX</span>
                    <span class="feature-pill">Active Yaw Control (AYC)</span>
                </div>
            </div>

            <!-- Simulasi Kredit -->
            <div class="product-card">
                <h2>Simulasi Kredit Xforce Jogja</h2>
                <p style="font-size: 0.9rem; margin-bottom: 1rem; color: var(--m-mid-grey);">Estimasi kredit Xforce Ultimate CVT (OTR Rp 428.500.000), DP 20%:</p>
                <div class="kredit-grid">
                    <div class="kredit-card">
                        <div class="k-label">DP 20%</div>
                        <div class="k-value">Rp 85,7 Jt</div>
                        <div class="k-sub">Dari Total OTR</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Cicilan/Bulan</div>
                        <div class="k-value">~Rp 10,4 Jt</div>
                        <div class="k-sub">Tenor 36 bulan</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Cicilan/Bulan</div>
                        <div class="k-value">~Rp 7,6 Jt</div>
                        <div class="k-sub">Tenor 60 bulan</div>
                    </div>
                    <div class="kredit-card">
                        <div class="k-label">Promo DP Ringan</div>
                        <div class="k-value">Mulai 15%</div>
                        <div class="k-sub">Silakan Konsultasi</div>
                    </div>
                </div>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey); margin-top: 12px;">* Simulasi perkiraan. Hubungi Putra untuk hitungan pasti &amp; nego diskon maksimal.</p>
            </div>

            <!-- Review / About -->
            <div class="product-card">
                <h2>Ideal Untuk Kondisi Jalan Jogja</h2>
                <ul class="about-list" style="margin-top: 0.5rem;">
                    <li><strong>Ground Clearance 222 mm:</strong> Bebas cemas melewati jalan berlubang atau genangan air hujan di Jogja.</li>
                    <li><strong>4 Mode Berkendara (Wet, Mud, Gravel, Normal):</strong> Sangat pas untuk menjelajah wisata alam Jogja dari pantai sampai gunung.</li>
                    <li><strong>Yamaha Premium Sound:</strong> Macet di jalanan Malioboro tidak akan terasa membosankan.</li>
                    <li><strong>Active Yaw Control (AYC):</strong> Tetap stabil bermanuver tajam.</li>
                </ul>
            </div>

        </div>

        <div class="product-sidebar">
            <SidebarCTA
                image="/images/xforce.webp"
                imageAlt="Xforce"
                price="Rp 382 Juta"
                waLink="https://wa.me/628974362666?text=Halo%20Putra%2C%20Boleh%20minta%20brosur%20dan%20harga%20promo%20Xforce%20di%20Jogja%3F"
                waButtonText="Tanya Promo Xforce"
                ctaId="wa-xforce-cta"
                features={["Test Drive Door to Door", "Audio Yamaha Premium", "Unit Ready Stock!"]}
            />

            <!-- Related Links -->
            <div class="sidebar-widget" style="margin-top: 1.5rem;">
                <h3>Produk Lainnya</h3>
                <ul class="sidebar-link-list">
                    <li><a href="/xpander-sleman.html">→ New Xpander Sleman</a></li>
                    <li><a href="/pajero-sport-sleman.html">→ Pajero Sport Sleman</a></li>
                    <li><a href="/#products">→ Lihat Semua Unit</a></li>
                </ul>
            </div>
            <div class="sidebar-widget" style="margin-top: 1.5rem;">
                <h3>Artikel Berguna</h3>
                <ul class="sidebar-link-list">
                    <li><a href="/blog/perbandingan-xpander-vs-xforce.html">Baca: Xpander vs Xforce</a></li>
                    <li><a href="/blog/kredit-mitsubishi-sleman.html">Tips Kredit Cepat Lolos</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Related -->
    <RelatedProducts products={[
        { title: "New Xpander Cross", price: "Rp 377.500.000", image: "/images/xpander-cross.webp", alt: "Xpander Cross Sleman", href: "/xpander-sleman.html" },
        { title: "Pajero Sport – Promo", price: "Rp 799.000.000", image: "/images/pajero-sport.webp", alt: "Pajero Sport Sleman", href: "/pajero-sport-sleman.html" }
    ]} />

    
</Layout>
