                <span class="price-main">Rp 374,5 Juta</span>
                <p style="font-size: 0.82rem; color: var(--m-mid-grey);">OTR Yogyakarta 2026</p>
                <a href="https://wa.me/628974362666?text=Halo%20Putra%2C%20saya%20tertarik%20Xforce%20di%20Jogja.%20Boleh%20info%20promo%20terkini%3F"
                    class="cta-btn" id="wa-xforce-cta" target="_blank" rel="noopener">
                    <i class="fab fa-whatsapp"></i> Chat Promo Xforce
                </a>
